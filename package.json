{
  "name": "metamcp-cli",
  "version": "0.1.0",
  "description": "CLI wrapper for MetaMCP — auto-configure MCP clients from your MetaMCP instance",
  "type": "module",
  "bin": {
    "metamcp-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "metamcp",
    "cli",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
